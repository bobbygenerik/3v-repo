rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Profile photos - users can upload files with their uid in the name
    match /profile_photos/{fileName} {
      allow read: if true; // Anyone can view profile photos
      allow write: if request.auth != null && 
                      (fileName.matches(request.auth.uid + '.*') || 
                       fileName == request.auth.uid);
    }
    
    // Translation audio files - authenticated users can upload
    match /translations/{fileName} {
      allow read, write: if request.auth != null;
    }
  }
}
