<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#00FFD1"
                android:endColor="#00B3FF" />
            <solid android:color="#FF181818" />
            <stroke android:width="2dp" android:color="#00FFD1" />
            <corners android:radius="16dp" />
            <padding android:left="16dp" android:right="16dp" android:top="12dp" android:bottom="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF181818" />
            <stroke android:width="1dp" android:color="#FF404040" />
            <corners android:radius="16dp" />
            <padding android:left="16dp" android:right="16dp" android:top="12dp" android:bottom="12dp" />
        </shape>
    </item>
</selector>