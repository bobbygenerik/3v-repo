[Unit]
Description=Translation Service
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/projects/3v-repo/vps-workflow
ExecStart=/home/ubuntu/projects/3v-repo/vps-workflow/venv/bin/gunicorn -w 4 -b 0.0.0.0:5000 server:app
Restart=always

[Install]
WantedBy=multi-user.target
