# ======================================
# Firebase Functions Environment Config
# ======================================

# ===== FIREBASE CONFIGURATION =====
# Get these from Firebase Console > Project Settings > Service Accounts
# Click "Generate new private key" and download the JSON file

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Note: Copy the entire private key including -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY-----
# Make sure to keep the \n newline characters
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ===== LIVEKIT CONFIGURATION =====
# Get these from LiveKit Cloud dashboard: https://cloud.livekit.io/
# Or use your self-hosted LiveKit server credentials

LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here
LIVEKIT_URL=wss://your-project.livekit.cloud

# ===== APPLICATION URLS =====
# Your Firebase Hosting URL (for guest invite redirects)
WEB_URL=https://your-firebase-project.web.app

# Your Flutter app deep link URL
APP_DEEP_LINK=tresvideo://

# ===== FEATURE FLAGS =====
# Enable/disable specific features in production
ENABLE_GUEST_TOKENS=true
ENABLE_RECORDING=true
ENABLE_ANALYTICS=true

# ===== RECORDING CONFIGURATION =====
# Where to store recordings (firebase-storage or custom)
RECORDING_STORAGE=firebase-storage
RECORDING_BUCKET=your-project.appspot.com

# ===== RATE LIMITING =====
# Requests per minute per user
RATE_LIMIT_TOKEN_GENERATION=10
RATE_LIMIT_RECORDING=5

# ===== SECURITY =====
# Token expiration time (in seconds)
GUEST_TOKEN_EXPIRY=3600
ROOM_TOKEN_EXPIRY=86400

# ===== SETUP INSTRUCTIONS =====
# 1. Copy this file to .env in the same directory:
#    cp .env.example .env
#
# 2. Fill in all values above with your actual credentials
#
# 3. NEVER commit the .env file to git (it's in .gitignore)
#
# 4. For local development, the .env file is sufficient
#
# 5. For Firebase deployment, you have two options:
#    
#    Option A: Use .env (recommended)
#    - The functions will automatically load .env file
#    - Make sure .env is deployed with your functions
#    
#    Option B: Use Firebase environment config
#    firebase functions:config:set \
#      firebase.project_id="your-project" \
#      firebase.client_email="..." \
#      firebase.private_key="..." \
#      livekit.api_key="..." \
#      livekit.api_secret="..." \
#      livekit.url="..."
#
# 6. Test your functions locally before deploying:
#    firebase emulators:start --only functions
#
# 7. Deploy to production:
#    firebase deploy --only functions

# ===== GETTING CREDENTIALS =====
#
# Firebase Service Account:
# 1. Go to Firebase Console > Project Settings
# 2. Click "Service accounts" tab
# 3. Click "Generate new private key"
# 4. Save the JSON file
# 5. Copy project_id, client_email, and private_key to this file
#
# LiveKit Credentials:
# Option A - Cloud (Recommended):
# 1. Go to https://cloud.livekit.io/
# 2. Create an account (free tier available)
# 3. Create a new project
# 4. Copy API Key, Secret, and WebSocket URL
#
# Option B - Self-Hosted:
# 1. Deploy LiveKit server using Docker or Kubernetes
# 2. Generate API key/secret in livekit.yaml config
# 3. Use your server's WebSocket URL
